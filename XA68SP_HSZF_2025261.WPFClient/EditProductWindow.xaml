<Window x:Class="XA68SP_HSZF_2025261.WPFClient.EditProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Termék szerkesztése" Height="400" Width="400"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20">
        <TextBlock Text="Név" />
        <TextBox x:Name="NameBox" />
        <TextBlock Text="Márka" />
        <TextBox x:Name="BrandBox" />
        <TextBlock Text="Kategória" />
        <TextBox x:Name="CategoryBox" />
        <TextBlock Text="Leírás" />
        <TextBox x:Name="DescriptionBox" />
        <TextBlock Text="Ár" />
        <TextBox x:Name="PriceBox" />
        <TextBlock Text="Készlet" />
        <TextBox x:Name="StockBox" />
        <Button Content="Mentés" Click="Save_Click" Margin="0,20,0,0"/>
    </StackPanel>
</Window>
