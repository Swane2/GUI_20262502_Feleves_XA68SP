<Window x:Class="XA68SP_HSZF_2025261.WPFClient.ProductDetailsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Termék részletei" Height="300" Width="400"
        WindowStartupLocation="CenterOwner">
    <StackPanel Margin="20">
        <TextBlock Text="{Binding Name, StringFormat='Név: {0}'}" FontSize="14" Margin="0,5"/>
        <TextBlock Text="{Binding Brand, StringFormat='Márka: {0}'}" Margin="0,5"/>
        <TextBlock Text="{Binding Category, StringFormat='Kategória: {0}'}" Margin="0,5"/>
        <TextBlock Text="{Binding Price, StringFormat='Ár: {0} Ft'}" Margin="0,5"/>
        <TextBlock Text="{Binding Stock, StringFormat='Készlet: {0} db'}" Margin="0,5"/>
        <TextBlock Text="{Binding Description, StringFormat='Leírás: {0}'}" Margin="0,5" TextWrapping="Wrap"/>
        <Button Content="OK" Click="OK_Click" Margin="0,20,0,0" Width="80" HorizontalAlignment="Right"/>
    </StackPanel>
</Window>
